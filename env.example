# ── Required ──
# Tunnel token (eyJ... string). Get from Cloudflare dashboard:
#   Networking → Tunnels → your tunnel → Add a replica → copy the eyJ... token
TUNNEL_TOKEN=""

# Public hostname mapped to the tunnel (NOT derivable from the token)
PUBLIC_HOSTNAME="argo-yg.7786.pp.ua"

# Caddy listen port (also cloudflared ingress target)
LOCAL_PORT="8088"

# Upstream backend to proxy to (host:port)
UPSTREAM="api-sgp-oc.xiaomimimo.com:443"

# ── Optional ──
# Client-side auth: if set, Caddy requires "Authorization: Bearer <PROXY_API_KEY>"
# from every client (rejects others with 401). Strongly recommended for public
# endpoints — without it, anyone who finds your tunnel URL can use your upstream.
PROXY_API_KEY=""

# Env var name holding the upstream API key to inject as Authorization + x-api-key.
# If unset, no upstream auth injection (plain proxy to upstream).
# Example for MiMo: API_KEY_ENV="MIMO_API_KEY" + export MIMO_API_KEY="sk-..."
API_KEY_ENV=""

# Extra Caddy listen ports (Cloudflare Dashboard may push traffic here)
DASHBOARD_PORT="62852"
EXTRA_PORT="7860"

# Local port for the OpenAI compatibility shim. Defaults to LOCAL_PORT + 1.
# Caddy listens on LOCAL_PORT and forwards to this shim.
SHIM_PORT="8089"

# Caddy release version
CADDY_VERSION="2.11.3"

# Force upstream TLS (default: true if UPSTREAM port is 443, else false)
# UPSTREAM_TLS="true"

# Python binary used by the compatibility shim (auto-detected if unset)
# PYTHON_BIN="python3"

# ── If API_KEY_ENV is set, also export the actual key value ──
# export MIMO_API_KEY="sk-your-api-key-here"
